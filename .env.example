# CredentialDOMD Environment Variables
# Copy this file to .env and fill in your values.

# Supabase (required for cloud sync and cross-device access)
# Get your project URL and anon key from: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Gemini API Key (required for AI document scanning and CPT lookup)
# Get your key at: https://aistudio.google.com/apikey
# NOTE: In the current client-side architecture, this key is stored in the browser.
# For production deployment, route API calls through a backend proxy instead.
VITE_GEMINI_API_KEY=your-gemini-key-here

# NPI Proxy URL (optional, for production web deployment)
# The NPPES API doesn't support CORS, so a proxy is needed for browser access.
# In development, the Vite dev server proxies requests automatically.
# For production, deploy a serverless proxy (Cloudflare Worker, Vercel Edge Function)
# and set the URL here.
# VITE_NPI_PROXY_URL=https://your-proxy.workers.dev/npi

# Stripe Price IDs (required for subscription checkout)
# Get your price IDs from: https://dashboard.stripe.com/products
# Create two products: "CredentialDOMD Pro" and "CredentialDOMD Practice"
VITE_STRIPE_PRICE_PRO_MONTHLY=price_xxxxxxxxxxxxxxxxxxxxxxxx
VITE_STRIPE_PRICE_PRO_ANNUAL=price_xxxxxxxxxxxxxxxxxxxxxxxx
VITE_STRIPE_PRICE_PRACTICE=price_xxxxxxxxxxxxxxxxxxxxxxxx

# Supabase Edge Function environment variables (set in Supabase dashboard → Edge Functions → Secrets):
# STRIPE_SECRET_KEY=<your-stripe-secret-key>
# STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-secret>
# STRIPE_PRICE_ID_PRO_ANNUAL=<price_id>  (used by webhook to detect plan)
# STRIPE_PRICE_ID_PRACTICE=<price_id>
